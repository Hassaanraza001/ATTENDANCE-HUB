rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // --- System Status (For Raspberry Pi Heartbeat & Pairing) ---
    match /system_status/{deviceId} {
      // Allow the device (anonymous) to update its status
      allow read, write: if true; 
    }

    // --- Kiosk Commands (For Enrollment & Remote Actions) ---
    match /kiosk_commands/{commandId} {
      // Allow Kiosk UI and Dashboard to send commands, and Pi to read/update them
      allow read, write: if true;
    }

    // --- Students (Unified Collection) ---
    match /students/{studentId} {
      // Allow read/write if the student belongs to the logged-in user
      // Or allow public read for the Kiosk UI (anonymous)
      allow read: if true;
      allow create, update, delete: if true; 
    }

    // --- App Users (Profiles) ---
    match /appUsers/{appUserId} {
      allow get, list: if isSignedIn() && request.auth.uid == appUserId;
      allow create: if isSignedIn() && request.auth.uid == appUserId;
      allow update: if isSignedIn() && request.auth.uid == appUserId;
    }

    // --- Faculty ---
    match /faculties/{facultyId} {
      allow read, write: if isSignedIn();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}